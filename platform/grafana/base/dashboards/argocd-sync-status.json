{
  "annotations": {
    "list": []
  },
  "description": "Argo CD sync status — sync state by application, sync duration, and reconciliation errors",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Application Sync Status",
      "type": "stat",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OutOfSync", "color": "red" }, "1": { "text": "Synced", "color": "green" } } }
          ]
        }
      },
      "targets": [
        {
          "expr": "argocd_app_info{sync_status=\"Synced\"}",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Sync Status by Application",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "argocd_app_info",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "includeByName": {
              "name": true,
              "project": true,
              "sync_status": true,
              "health_status": true,
              "dest_server": true
            }
          }
        }
      ]
    },
    {
      "title": "Sync Duration by Application",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50
          }
        }
      },
      "targets": [
        {
          "expr": "argocd_app_sync_total{phase=\"Succeeded\"} - argocd_app_sync_total{phase=\"Succeeded\"} offset 5m",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Reconciliation Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(argocd_app_reconcile_errors_total[5m])) by (name)",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Sync Failures Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(argocd_app_sync_total{phase=~\"Error|Failed\"}[5m])) by (name, phase)",
          "legendFormat": "{{ name }} ({{ phase }})",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["argocd", "gitops"],
  "templating": {
    "list": [
      {
        "name": "project",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(argocd_app_info, project)",
        "refresh": 2,
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Argo CD Sync Status",
  "uid": "argocd-sync-status"
}
